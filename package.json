{
    "name": "@protontech/telemetry",
    "version": "1.0.5",
    "description": "Frontend telemetry library for Proton websites",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ProtonMail/proton-telemetry.git"
    },
    "license": "GPL-3.0-or-later",
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:cover": "vitest run --coverage",
        "lint": "eslint . --quiet",
        "release:prepare": "pnpm run lint && pnpm run test && pnpm run build",
        "version:patch": "npm version patch",
        "version:minor": "npm version minor",
        "version:major": "npm version major",
        "publish:prepare": "npm run build && git add dist -f",
        "push:tags": "git push --follow-tags"
    },
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@types/node": "^22.15.21",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "@vitest/coverage-v8": "^4.0.0",
        "eslint": "10.4.1",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-prettier": "^5.5.6",
        "happy-dom": "20.10.2",
        "prettier": "^3.8.3",
        "typescript": "6.0.3",
        "vite": "^8.0.0",
        "vitest": "4.1.8"
    },
    "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
    "pnpm": {
        "overrides": {
            "esbuild": ">=0.25.0"
        }
    }
}
